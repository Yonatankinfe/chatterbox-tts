        "import torch\n",
        "import torchaudio\n",
        "\n",
        "def generate_speech(text, config, model, output_filename=\"generated_speech.wav\"):\n",
        "    \"\"\"Generate speech from text using Chatterbox TTS\"\"\"\n",
        "    \n",
        "    print(\"=\" * 60)\n",
        "    print(\"🎙️ GENERATING SPEECH\")\n",
        "    print(\"=\" * 60)\n",
        "    \n",
        "    # Analyze text\n",
        "    chunks = split_into_chunks(text, config.max_chunk_words)\n",
        "    word_count, time_est = estimate_processing_time(text)\n",
        "    \n",
        "    print(f\"\\n📝 Text analysis:\")\n",
        "    print(f\"   Words: {word_count}\")\n",
        "    print(f\"   Chunks: {len(chunks)}\")\n",
        "    print(f\"   Est. time: {time_est:.1f} min\")\n",
        "    print(f\"\\n🎛️ Settings:\")\n",
        "    print(f\"   Exaggeration: {config.exaggeration}\")\n",
        "    print(f\"   CFG Weight: {config.cfg_weight}\")\n",
        "    \n",
        "    # Voice cloning status\n",
        "    if config.voice_sample_path and os.path.exists(config.voice_sample_path):\n",
        "        print(f\"\\n🎤 Voice cloning: ENABLED\")\n",
        "        print(f\"   Sample: {config.voice_sample_path}\")\n",
        "    else:\n",
        "        print(f\"\\n🤖 Voice cloning: DISABLED (default voice)\")\n",
        "    \n",
        "    print(\"\\n\" + \"-\" * 40)\n",
        "    print(\"🔄 Processing chunks...\")\n",
        "    print(\"-\" * 40)\n",
        "    \n",
        "    wav_tensors = []\n",
        "    \n",
        "    for i, chunk in enumerate(chunks):\n",
        "        preview = chunk[:50] + \"...\" if len(chunk) > 50 else chunk\n",
        "        print(f\"\\n📦 Chunk {i+1}/{len(chunks)}: \\\"{preview}\\\"\")\n",
        "        \n",
        "        try:\n",
        "            gen_params = {\n",
        "                \"text\": chunk,\n",
        "                \"exaggeration\": config.exaggeration,\n",
        "                \"cfg_weight\": config.cfg_weight\n",
        "            }\n",
        "            \n",
        "            if config.voice_sample_path and os.path.exists(config.voice_sample_path):\n",
        "                gen_params[\"audio_prompt_path\"] = config.voice_sample_path\n",
        "            \n",
        "            wav = model.generate(**gen_params)\n",
        "            wav_tensors.append(wav)\n",
        "            print(f\"   ✅ Generated {wav.shape[1]/model.sr:.2f}s of audio\")\n",
        "            \n",
        "            # Clear GPU cache\n",
        "            if torch.cuda.is_available():\n",
        "                torch.cuda.empty_cache()\n",
        "                \n",
        "        except Exception as e:\n",
        "            print(f\"   ❌ Error: {e}\")\n",
        "            continue\n",
        "    \n",
        "    if not wav_tensors:\n",
        "        print(\"\\n❌ No audio was generated\")\n",
        "        return None, None\n",
        "    \n",
        "    # Combine all chunks\n",
        "    print(\"\\n\" + \"-\" * 40)\n",
        "    print(\"💾 Saving audio...\")\n",
        "    full_audio = torch.cat(wav_tensors, dim=1)\n",
        "    duration = full_audio.shape[1] / model.sr\n",
        "    \n",
        "    output_path = None\n",
        "    local_path = f\"/content/{output_filename}\"\n",
        "    \n",
        "    # Save locally\n",
        "    torchaudio.save(local_path, full_audio, model.sr)\n",
        "    print(f\"   📱 Local: {local_path}\")\n",
        "    \n",
        "    # Save to Drive if available\n",
        "    if DRIVE_PATH:\n",
        "        output_path = f\"{DRIVE_PATH}/{output_filename}\"\n",
        "        torchaudio.save(output_path, full_audio, model.sr)\n",
        "        print(f\"   💾 Drive: {output_path}\")\n",
        "    \n",
        "    print(f\"\\n✅ Generation complete!\")\n",
        "    print(f\"   Duration: {duration:.2f} seconds\")\n",
        "    \n",
        "    return output_path, local_path\n",
        "\n",
