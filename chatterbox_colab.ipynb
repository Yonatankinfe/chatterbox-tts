        "import IPython.display as ipd\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "def play_and_analyze_audio(audio_path):\n",
        "    \"\"\"Play audio and display waveform visualization\"\"\"\n",
        "    \n",
        "    if not audio_path or not os.path.exists(audio_path):\n",
        "        print(\"❌ No audio file found to play\")\n",
        "        print(\"   Make sure you ran Cell 6 successfully\")\n",
        "        return\n",
        "    \n",
        "    print(\"=\" * 60)\n",
        "    print(\"🔊 AUDIO PLAYBACK & ANALYSIS\")\n",
        "    print(\"=\" * 60)\n",
        "    \n",
        "    # Display audio player\n",
        "    print(f\"\\n🎵 File: {os.path.basename(audio_path)}\")\n",
        "    print(\"\\n▶️ Audio Player:\")\n",
        "    ipd.display(ipd.Audio(audio_path))\n",
        "    \n",
        "    # Analyze and visualize\n",
        "    try:\n",
        "        waveform, sample_rate = torchaudio.load(audio_path)\n",
        "        duration = waveform.shape[1] / sample_rate\n",
        "        \n",
        "        print(f\"\\n📊 Audio Statistics:\")\n",
        "        print(f\"   Duration: {duration:.2f} seconds\")\n",
        "        print(f\"   Sample Rate: {sample_rate} Hz\")\n",
        "        print(f\"   Channels: {waveform.shape[0]}\")\n",
        "        print(f\"   Samples: {waveform.shape[1]:,}\")\n",
        "        \n",
        "        # Calculate audio levels\n",
        "        audio_np = waveform[0].numpy()\n",
        "        print(f\"   Peak amplitude: {np.max(np.abs(audio_np)):.3f}\")\n",
        "        print(f\"   RMS level: {np.sqrt(np.mean(audio_np**2)):.3f}\")\n",
        "        \n",
        "        # Plot waveform\n",
        "        print(\"\\n📈 Waveform:\")\n",
        "        plt.figure(figsize=(14, 4))\n",
        "        \n",
        "        # Create time axis\n",
        "        time_axis = np.linspace(0, duration, len(audio_np))\n",
        "        \n",
        "        plt.plot(time_axis, audio_np, color='#2E86AB', linewidth=0.5)\n",
        "        plt.fill_between(time_axis, audio_np, alpha=0.3, color='#2E86AB')\n",
        "        plt.title(f\"Generated Audio Waveform ({duration:.2f}s)\", fontsize=14, fontweight='bold')\n",
        "        plt.xlabel(\"Time (seconds)\", fontsize=12)\n",
        "        plt.ylabel(\"Amplitude\", fontsize=12)\n",
        "        plt.grid(True, alpha=0.3, linestyle='--')\n",
        "        plt.xlim(0, duration)\n",
        "        plt.ylim(-1.1, 1.1)\n",
        "        \n",
        "        # Add zero line\n",
        "        plt.axhline(y=0, color='gray', linestyle='-', alpha=0.3, linewidth=0.5)\n",
        "        \n",
        "        plt.tight_layout()\n",
        "        plt.show()\n",
        "        \n",
