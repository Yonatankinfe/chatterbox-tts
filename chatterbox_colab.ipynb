        "from google.colab import drive\n",
        "import os\n",
        "import torch\n",
        "from chatterbox.tts import ChatterboxTTS\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"📂 SETTING UP ENVIRONMENT\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "# Mount Google Drive\n",
        "def setup_drive():\n",
        "    \"\"\"Mount Google Drive and create Chatterbox folder\"\"\"\n",
        "    print(\"\\n📁 Mounting Google Drive...\")\n",
        "    try:\n",
        "        drive.mount('/content/drive')\n",
        "        drive_path = '/content/drive/MyDrive/Chatterbox'\n",
        "        os.makedirs(drive_path, exist_ok=True)\n",
        "        print(f\"✅ Drive mounted: {drive_path}\")\n",
        "        return drive_path\n",
        "    except Exception as e:\n",
        "        print(f\"⚠️  Drive mount failed: {e}\")\n",
        "        print(\"   Continuing without Drive integration...\")\n",
        "        return None\n",
        "\n",
        "DRIVE_PATH = setup_drive()\n",
        "\n",
        "# Load Chatterbox model\n",
        "def load_model():\n",
        "    \"\"\"Load Chatterbox TTS model with GPU/CPU fallback\"\"\"\n",
        "    print(\"\\n🤖 Loading Chatterbox TTS model...\")\n",
        "    \n",
        "    try:\n",
        "        device = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
        "        print(f\"   Target device: {device.upper()}\")\n",
        "        \n",
        "        model = ChatterboxTTS.from_pretrained(device=device)\n",
        "        print(f\"✅ Model loaded on {device.upper()}\")\n",
        "        return model\n",
        "        \n",
        "    except Exception as e:\n",
        "        print(f\"⚠️  GPU load failed: {e}\")\n",
        "        print(\"   Falling back to CPU...\")\n",
        "        \n",
        "        try:\n",
        "            model = ChatterboxTTS.from_pretrained(device=\"cpu\")\n",
        "            print(\"✅ Model loaded on CPU\")\n",
        "            return model\n",
        "        except Exception as e2:\n",
        "            print(f\"❌ CPU fallback also failed: {e2}\")\n",
        "            raise e2\n",
        "\n",
        "model = load_model()\n",
        "\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"✅ SETUP COMPLETE!\")\n",
        "print(\"=\" * 60)"
      ]
